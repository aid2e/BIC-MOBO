{
    "_comment"      : "Configures runtime options, and paths to EIC software components",
    "conda"         : "<path-to-your-script>/conda.sh",
    "environment"   : "bic-mobo",
    "out_path"      : "$BIC_MOBO/out",
    "run_path"      : "$BIC_MOBO/run",
    "log_path"      : "$BIC_MOBO/log",
    "eic_shell"     : "$BIC_MOBO/run_singularity.sh",
    "overlap_check" : "checkOverlaps",
    "epic_setup"    : "$BIC_MOBO/epic/install/bin/thisepic.sh",
    "det_path"      : "$BIC_MOBO/epic/install/share/epic",
    "cmake_path"    : "$BIC_MOBO/epic",
    "det_config"    : "epic",
    "sim_exec"      : "npsim",
    "sim_input"     : {
        "single_electron" : {
            "location" : "$BIC_MOBO/steering/electron",
            "type"     : "gun"
        },
        "single_piminus" : {
            "location" : "$BIC_MOBO/steering/piminus",
            "type"     : "gun"
        },
        "single_pizero" : {
            "_comment" : "currently unused",
            "location" : "$BIC_MOBO/steering/pizero",
            "type"     : "gun"
        },
        "single_gamma" : {
            "_comment" : "currently unused",
            "location" : "$BIC_MOBO/steering/gammma",
            "type"     : "gun"
        }
    },
    "rec_exec"    : "eicrecon",
    "rec_collect" : [
        "MCParticles",
        "GeneratedParticles",
        "EcalBarrelScFiRawHits",
        "EcalBarrelScFiRawHitAssociations",
        "EcalBarrelScFiRecHits",
        "EcalBarrelScFiClusters",
        "EcalBarrelScFiClusterAssociations",
        "EcalBarrelImagingRawHits",
        "EcalBarrelImagingRawHitAssociations",
        "EcalBarrelImagingRecHits",
        "EcalBarrelImagingClusters",
        "EcalBarrelImagingClusterAssociations",
        "EcalBarrelClusters",
        "EcalBarrelClusterAssociations",
        "EcalBarrelTruthClusters",
        "EcalBarrelTruthClusterAssociations"
    ],
    "sched_n_jobs"        : 1,
    "monitoring_interval" : 30
}
